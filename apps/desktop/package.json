{
  "name": "@inumaki/desktop",
  "version": "0.1.7",
  "private": true,
  "description": "Inumaki AI — voice-to-text dictation for Windows.",
  "author": "Camie Tech",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev:vite\" \"pnpm dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@inumaki/shared": "workspace:*",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "node-global-key-listener": "^0.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "ai.inumaki.desktop",
    "productName": "Inumaki AI",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Camie-Tech",
        "repo": "inumaki"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png",
      "verifyUpdateCodeSignature": false
    },
    "asarUnpack": [
      "node_modules/node-global-key-listener/bin/WinKeyServer.exe"
    ],
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../../releases/inumaki-oss/Inumaki-AI-0.1.1-win-unpacked/win-unpacked/resources/whisper",
        "to": "whisper"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Inumaki-AI-Setup.${ext}"
    },
    "portable": {
      "artifactName": "Inumaki-AI-Portable.${ext}"
    }
  }
}
