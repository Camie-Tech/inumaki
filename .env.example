# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/inumaki"

# ─── NextAuth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Magic Link (SMTP) ────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASS="smtp-password"
SMTP_FROM="Inumaki AI <noreply@example.com>"

# ─── Access Control ───────────────────────────────────────────────
# Comma-separated. Either domain-based OR specific emails, or both.
# Example: ALLOWED_EMAIL_DOMAINS="yourcompany.com,partner.io"
ALLOWED_EMAIL_DOMAINS="yourcompany.com"
# Example: ALLOWED_EMAILS="alice@external.com,bob@contractor.dev"
ALLOWED_EMAILS=""

# ─── OpenAI ───────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ─── Desktop app store encryption (optional) ──────────────────────
# If set, electron-store will encrypt local settings on disk
STORE_ENCRYPTION_KEY=""
